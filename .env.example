PORT=8080

# Dev: mongodb://mongo:27017 | Prod: mongodb://mongodb:27017
MONGO_URI=mongodb://mongodb:27017

# Internal MinIO endpoint (container-to-container)
# Dev: minio:9000 | Prod: minio:9000
MINIO_ENDPOINT=minio:9000

# Public-facing MinIO URL (used for presigned download URL rewriting)
# Dev: localhost:9000 | Prod: your-public-domain.com
MINIO_PUBLIC_ENDPOINT=localhost:9000

# Path prefix used to rewrite presigned URLs through the nginx reverse proxy
# Dev: /minio | Prod: /minio
# Leave empty to return raw MinIO URLs (only if MinIO is publicly exposed)
MINIO_DOWNLOAD_PREFIX=/minio

MINIO_BUCKET=filex
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# development | production
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://filex.example.com